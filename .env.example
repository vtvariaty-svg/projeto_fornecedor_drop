# =============================================
# DATABASE (Neon PostgreSQL)
# DATABASE_URL  → pooled via PgBouncer (runtime)
# DIRECT_URL    → conexão direta sem pooler (migrations)
# =============================================
DATABASE_URL=
DIRECT_URL=

# =============================================
# AUTH JWT
# =============================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# FRONTEND
# =============================================
NEXT_PUBLIC_API_URL=

# =============================================
# REDIS / FILAS (fase futura)
# =============================================
REDIS_URL=

# =============================================
# STORAGE S3-compatible (fase futura)
# =============================================
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
