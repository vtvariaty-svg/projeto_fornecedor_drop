# FRONTEND
# =============================================
NEXT_PUBLIC_API_URL=

# =============================================
# REDIS / FILAS (para fase futura com BullMQ)
# =============================================
REDIS_URL=

# =============================================
# STORAGE S3-compatible (para fase futura)
# =============================================
