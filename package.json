{
  "name": "plataforma-drop",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:worker": "pnpm --filter worker build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter database prisma generate",
    "db:validate": "pnpm --filter database prisma validate",
    "db:migrate": "pnpm --filter database prisma migrate dev",
    "db:studio": "pnpm --filter database prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
