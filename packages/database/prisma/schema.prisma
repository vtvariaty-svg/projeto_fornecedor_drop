// =============================================
// Prisma Schema — Plataforma B2B Dropshipping
// Banco: Neon PostgreSQL
// DATABASE_URL  → runtime (pooled via PgBouncer)
// DIRECT_URL    → migrations (direct connection)
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  TENANT_OWNER
  TENANT_ADMIN
  TENANT_MEMBER
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BrandStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PENDING_FULFILLMENT
  FULFILLMENT_IN_PROGRESS
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  PREPARING
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CHARGEBACK
  MANUAL_CONFIRMED
}

enum InventoryMovementType {
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RESERVATION
  RELEASE_RESERVATION
  COMMIT_RESERVATION
  MANUAL_CORRECTION
  RETURN
}

enum AssetType {
  LOGO
  BANNER
  LABEL
  PACKAGING
  ICON
  OTHER
}

enum CustomizationOptionType {
  LOGO
  TAG
  INTERNAL_LABEL
  THANK_YOU_CARD
  PACKAGING
  COLOR
  MATERIAL
  HARDWARE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PERMISSION_CHANGE
  STATUS_CHANGE
  PAYMENT_ACTION
  SYSTEM
}

// =============================================
// USER & TENANT
// =============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         UserRole @default(TENANT_MEMBER)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants       TenantUser[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([createdAt])
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users    TenantUser[]
  brands   Brand[]
  orders   Order[]
  wallet   Wallet?

  @@index([slug])
  @@index([status])
  @@index([createdAt])
}

model TenantUser {
  id        String   @id @default(cuid())
  role      UserRole @default(TENANT_MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  userId   String

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// Refresh tokens — hash SHA-256 do token gerado, nunca o token em texto puro
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

// =============================================
// BRAND
// =============================================

model Brand {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  status      BrandStatus @default(DRAFT)

  // Identidade basica da marca (Brand Studio)
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  toneOfVoice    String?
  brandStory     String?
  guidelines     String?

  // Campos de aprovacao
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  reviewedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  assets BrandAsset[]
  orders Order[]

  @@index([tenantId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
}

model BrandAsset {
  id         String    @id @default(cuid())
  type       AssetType
  url        String
  filename   String
  mimeType   String
  storageKey String?
  altText    String?
  sortOrder  Int       @default(0)
  isApproved       Boolean   @default(false)
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectedReason   String?
  reviewedByUserId String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  @@index([brandId])
  @@index([type])
}

// =============================================
// CATALOG
// =============================================

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  status      ProductStatus @default(DRAFT)
  category    String?
  basePrice   Decimal       @db.Decimal(12, 2)
  costPrice   Decimal?      @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  variants             ProductVariant[]
  media                ProductMedia[]
  customizationOptions ProductCustomizationOption[]

  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ProductVariant {
  id          String        @id @default(cuid())
  sku         String        @unique
  name        String
  color       String?
  material    String?
  size        String?
  hardware    String?
  salePrice   Decimal       @db.Decimal(12, 2)
  costPrice   Decimal?      @db.Decimal(12, 2)
  weightGrams Int?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id])

  inventoryItem InventoryItem?
  orderItems    OrderItem[]
  media         ProductMedia[]

  @@index([sku])
  @@index([productId])
  @@index([status])
}

model ProductMedia {
  id         String   @id @default(cuid())
  url        String
  storageKey String?
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
}

model CustomizationOption {
  id               String                   @id @default(cuid())
  name             String
  description      String?
  type             CustomizationOptionType?
  isActive         Boolean                  @default(true)
  requiresApproval Boolean                  @default(false)
  additionalPrice  Decimal?                 @db.Decimal(12, 2)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  productOptions ProductCustomizationOption[]

  @@index([isActive])
}

model ProductCustomizationOption {
  id              String   @id @default(cuid())
  isRequired      Boolean  @default(false)
  additionalPrice Decimal? @db.Decimal(12, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productId             String
  customizationOptionId String

  product             Product             @relation(fields: [productId], references: [id])
  customizationOption CustomizationOption @relation(fields: [customizationOptionId], references: [id])

  @@unique([productId, customizationOptionId])
  @@index([productId])
  @@index([customizationOptionId])
}

// =============================================
// INVENTORY
// =============================================

model InventoryItem {
  id                String   @id @default(cuid())
  quantityAvailable Int      @default(0)
  quantityReserved  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  productVariantId String         @unique
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  movements InventoryMovement[]

  @@index([productVariantId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  type            InventoryMovementType
  quantity        Int
  reason          String?
  variantId       String
  referenceType   String?
  referenceId     String?
  createdByUserId String?
  createdAt       DateTime              @default(now())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([variantId])
  @@index([type])
  @@index([createdByUserId])
  @@index([createdAt])
}

// =============================================
// ORDERS
// =============================================

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  status        OrderStatus   @default(CONFIRMED)
  paymentStatus PaymentStatus @default(MANUAL_CONFIRMED)
  notes         String?

  // Dados do cliente final (sensíveis — nunca logar)
  customerName  String
  customerEmail String?
  customerPhone String?

  // Endereço de entrega como JSON estruturado
  shippingAddressJson Json

  // Valores financeiros
  subtotalAmount Decimal @default(0) @db.Decimal(12, 2)
  shippingAmount Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @default(0) @db.Decimal(12, 2)
  // Campo legado mantido por compatibilidade
  total          Decimal @default(0) @db.Decimal(12, 2)

  hasCustomization Boolean   @default(false)
  createdByUserId  String?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  shipments     Shipment[]
  payment       Payment?

  @@index([tenantId])
  @@index([brandId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id String @id @default(cuid())

  // Snapshot dos dados comerciais no momento da compra
  productId            String
  productVariantId     String
  skuSnapshot          String
  productNameSnapshot  String
  variantNameSnapshot  String
  unitPriceSnapshot    Decimal @db.Decimal(12, 2)
  customizationSnapshot Json   @default("{}")

  isCustomized        Boolean  @default(false)
  customizationNotes  String?

  // Campos legados mantidos por compatibilidade
  snapshotName          String
  snapshotSku           String
  snapshotPrice         Decimal @db.Decimal(12, 2)
  snapshotCustomization Json?
  unitPrice             Decimal @db.Decimal(12, 2)
  total                 Decimal @db.Decimal(12, 2)

  quantity       Int
  subtotalAmount Decimal @db.Decimal(12, 2)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
  @@index([skuSnapshot])
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  fromStatus OrderStatus?
  toStatus   OrderStatus
  // Campo legado mantido por compatibilidade
  status     OrderStatus
  reason     String?
  note       String?
  createdByUserId String?
  createdAt  DateTime    @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([toStatus])
  @@index([createdAt])
}

// =============================================
// FULFILLMENT
// =============================================

model Shipment {
  id           String         @id @default(cuid())
  status       ShipmentStatus @default(PENDING)
  carrier      String?
  trackingCode String?
  trackingUrl  String?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

// =============================================
// BILLING
// =============================================

model Payment {
  id          String        @id @default(cuid())
  status      PaymentStatus @default(PENDING)
  method      String?
  amount      Decimal       @db.Decimal(12, 2)
  externalRef String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderId  String  @unique
  order    Order   @relation(fields: [orderId], references: [id])
  tenantId String?

  @@index([status])
  @@index([orderId])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  transactions WalletTransaction[]

  @@index([tenantId])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(12, 2)
  type        String
  description String?
  externalRef String?
  createdAt   DateTime @default(now())

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([createdAt])
}

// =============================================
// AUDIT
// =============================================

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}
